# Copy to .env and fill in values
# Usage: cp .env.example .env && micro .env

# ── Timezone & Locale ─────────────────────────────────────────────────────────
TIMEZONE=Europe/Berlin
LOCALE=de_DE.UTF-8

# ── Tailscale ─────────────────────────────────────────────────────────────────
# Get from: https://login.tailscale.com/admin/settings/keys
# Leave empty to skip auto-join (run 'tailscale up' manually after)
TS_AUTHKEY=

# ── ProxmoxMCP-Plus ───────────────────────────────────────────────────────────
# Proxmox host IP or hostname (without https://)
PROXMOX_HOST=192.168.1.x

# Proxmox user (format: user@realm)
PROXMOX_USER=root@pam

# API token: create in PVE → Datacenter → Permissions → API Tokens
# Recommended: root@pam, token-id "mcp-token", Privilege Separation OFF
PROXMOX_TOKEN_NAME=mcp-token
PROXMOX_TOKEN_VALUE=
